# Database (use Supabase pooler URL for production)
# DATABASE_URL=postgresql://ai_marketing:ai_marketing_pass@localhost:5433/ai_marketing
DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# JWT (legacy - for backwards compatibility)
JWT_SECRET=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Google Gemini AI
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Pexels API (free stock videos - get key at https://www.pexels.com/api/)
PEXELS_API_KEY=your-pexels-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Facebook OAuth (for Facebook & Instagram posting)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Pre-configured Facebook Page (optional - for Quick Connect without OAuth)
# Get Page Access Token from: https://developers.facebook.com/tools/explorer/
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_NAME=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Pre-configured Instagram Account (optional - for Quick Connect without OAuth)
# Instagram Business Account connected to your Facebook Page
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_USERNAME=
INSTAGRAM_ACCESS_TOKEN=

# CORS
FRONTEND_URL=http://localhost:3000
